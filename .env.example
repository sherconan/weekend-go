# weekend-go 环境变量
# 复制为 .env 填入真实值。.env 不进 git。

# ====== LLM (DeepSeek V4 PRO direct, sage-jury stack) ======
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-ecc1c225fe1047218f4935ae251dfe3c
LLM_MODEL=deepseek-v4-pro

# Legacy fallback (server.js still reads ANTHROPIC_API_KEY if LLM_API_KEY empty)
ANTHROPIC_API_KEY=

# ====== Endpoints / URLs ======
# 应用 base path（部署在子目录时用）
BASE=

# 静态资源 CDN base URL
CDN_BASE=

# 都市传说卡 CDN base
CDN_LEGENDS_BASE=

# ====== 路径 ======
# XHS 登录态文件路径
COOKIE_PATH=

# 
PROFILE_DIR=

# ====== 数值参数 ======
# 上限值
MAX=

# 重试上限
