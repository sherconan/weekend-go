# weekend-go 环境变量
# 复制为 .env 填入真实值。.env 不进 git。

# ====== API Keys / Tokens ======
# Claude API key（用于内容生成 / 翻译）
ANTHROPIC_API_KEY=

# ====== Endpoints / URLs ======
# 应用 base path（部署在子目录时用）
BASE=

# 静态资源 CDN base URL
CDN_BASE=

# 都市传说卡 CDN base
CDN_LEGENDS_BASE=

# ====== 路径 ======
# XHS 登录态文件路径
COOKIE_PATH=

# 
PROFILE_DIR=

# ====== 数值参数 ======
# 上限值
MAX=

# 重试上限
MAX_ATTEMPTS=

# 
MAX_EXTRA_CITIES=

# 
MAX_RETRIES=

# 本地开发端口
PORT=

# ====== 其他 ======
# 深色模式样式（auto / on / off）
DARK_STYLE=

# GCP 服务账号 JSON 路径（用于 Vertex AI / TTS）
GOOGLE_APPLICATION_CREDENTIALS=

# 默认城市定位
LOCATION=

# 
MONTH=

# 
PROFILE=

# 
PROJECT_ID=

# 
ROOT=

# 
TARGET_H=

# 
TARGET_W=

# 
VERTEX_LOCATION=

# 
VERTEX_PROJECT_ID=
